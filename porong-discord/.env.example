DISCORD_TOKEN=your-bot-token-here
PORO_API_URL=http://localhost:8765
PORO_API_KEY=change-me-before-launch

# ─── 포로몬 인증 API (봇·MC 동일 호스트 전제 → 루프백 바인드) ─────────
# 실제 키는 절대 커밋하지 말 것. .env 에만 채운다.
POROMON_AUTH_URL=http://127.0.0.1:25580
POROMON_AUTH_KEY=change-me

GUILD_ID=your-guild-id

# 봇 SQLite 경로 (인스턴스 로컬 — 커밋 금지, *.sqlite3 는 gitignored)
BOT_DB_PATH=poro_bot.sqlite3
CHANNEL_AUTH_ID=your-auth-channel-id
CHANNEL_FIELD_BOSS_ID=your-field-boss-channel-id
# 운영/감사 로그 채널 (미설정/0 → DB(mod_log)만 적재, 채널 게시 생략)
CHANNEL_MODLOG_ID=0

# ─── 인바운드 알림 수신 (T1, 게임서버 → 봇 push) ───────────────────
# 보안: INBOUND_SECRET 과 INBOUND_PORT 가 둘 다 설정될 때만 리스너 기동.
# 실제 시크릿은 절대 커밋하지 말 것(.env 에만). HMAC-SHA256(body) 검증 키.
INBOUND_SECRET=
INBOUND_HOST=127.0.0.1
INBOUND_PORT=0
INBOUND_TS_TOLERANCE=300
# 허용 출발 IP (쉼표 구분, 비우면 IP 필터 생략): INBOUND_ALLOW_IPS=10.0.0.5,10.0.0.6
INBOUND_ALLOW_IPS=
# 알림 라우팅 공지 채널 (미설정/0 → 해당 알림 graceful skip)
CHANNEL_NOTICE_ID=0
CHANNEL_POROMON_NOTICE_ID=0

# 전역 단일 active 서버 모델: 시즌 사이 대기 역할 + 통합(공지·채팅) 카테고리
# (미설정/0 → 생애주기 일괄 역할 전이가 해당 부분 graceful skip)
ROLE_서버준비_ID=0
CATEGORY_통합_ID=0
# 티켓(1:1 문의) 생성 카테고리 (미설정/0 → 카테고리 없이 생성)
CATEGORY_티켓_ID=0
# 버그제보 게시 채널 (미설정/0 → /버그제보 비활성)
CHANNEL_BUGREPORT_ID=0

# 커뮤니티 레벨(T13) — XP 튜닝 + 레벨업 알림/제외 채널 (값 없으면 기본값 사용)
CHAT_XP_PER_MSG=15
CHAT_XP_COOLDOWN_SEC=60
VOICE_XP_PER_TICK=5
VOICE_TICK_SEC=60
CHANNEL_LEVELUP_ID=0
AFK_CHANNEL_ID=0
# XP 제외 채널 ID (쉼표 구분): XP_EXCLUDE_CHANNEL_IDS=123,456
XP_EXCLUDE_CHANNEL_IDS=
# 출석 보상 (T14): 보상 XP = BASE + min(streak, CAP) * PER_STREAK
ATTENDANCE_XP_BASE=100
ATTENDANCE_XP_PER_STREAK=10
ATTENDANCE_STREAK_CAP=30
ROLE_접속대기_ID=role-id
ROLE_인증유저_ID=role-id
TERMS_MESSAGE_ID=

# ─── 역할 ID (미설정 시 0 — 해당 기능 비활성화) ─────────────────
ROLE_미인증_ID=0
ROLE_검사_ID=0
ROLE_도끼전사_ID=0
ROLE_창기사_ID=0
ROLE_석궁사_ID=0
ROLE_낫사냥꾼_ID=0
ROLE_지팡이술사_ID=0
ROLE_필드보스알림_ID=0
ROLE_시즌보스알림_ID=0
ROLE_업데이트알림_ID=0

# ─── 멀티서버 온보딩 — 포로몬 (미설정 시 0 → 패널/전이 비활성) ──────
# 3단계 역할: 접근(임시) → 인증전(약관동의) → 플레이어(인증완료)
ROLE_포로몬접근_ID=0
ROLE_포로몬인증전_ID=0
ROLE_포로몬플레이어_ID=0
# 약관/인증 채널 (임시·인증전 역할에 send + use_application_commands 차단 = 읽기전용 권장)
CHANNEL_포로몬약관_ID=0
CHANNEL_포로몬인증_ID=0
